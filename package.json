{
  "name": "jobtailor",
  "displayName": "JobTailor",
  "version": "0.0.1",
  "description": "Tailor your CV to every job",
  "author": "Roberto Tom\u00e9 <contact@robtome.com>",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package"
  },
  "dependencies": {
    "@plasmohq/messaging": "^0.7.2",
    "@plasmohq/storage": "^1.0.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tailwindcss": "3.4.1"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "postcss": "8.4.33",
    "prettier": "3.2.4",
    "typescript": "5.3.3"
  },
  "manifest": {
    "permissions": [
      "activeTab",
      "scripting",
      "contextMenus",
      "notifications",
      "storage",
      "downloads",
      "identity"
    ],
    "oauth2": {
      "client_id": "67775878924-1qlfv8huro0qkitm7ejiljit1i06fq7j.apps.googleusercontent.com",
      "scopes": [
        "https://www.googleapis.com/auth/drive.appdata"
      ]
    },
    "host_permissions": [
      "https://www.googleapis.com/*",
      "https://oauth2.googleapis.com/*",
      "*://*.linkedin.com/*",
      "*://ollama.com/*",
      "*://www.ollama.com/*"
    ],
    "options_ui": {
      "page": "options.html",
      "open_in_tab": true
    }
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "@swc/core",
      "esbuild",
      "sharp",
      "lmdb",
      "msgpackr-extract"
    ]
  }
}